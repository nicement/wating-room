# ──────────────────────────────────────────────
# Server
# ──────────────────────────────────────────────
PORT=3000
# NODE_ENV=production

# ──────────────────────────────────────────────
# Redis
# ──────────────────────────────────────────────
# Local development: redis://localhost:6379
# Docker Compose:    redis://redis:6379
REDIS_URL=redis://localhost:6379

# ──────────────────────────────────────────────
# Queue
# ──────────────────────────────────────────────
# Maximum concurrent users allowed on the destination server
MAX_CAPACITY=10000

# ──────────────────────────────────────────────
# JWT
# ──────────────────────────────────────────────
# ⚠️  MUST be changed in production!
JWT_SECRET=super_secret_key_change_me_in_prod
JWT_EXPIRES_IN=5m

# ──────────────────────────────────────────────
# Rate Limiting
# ──────────────────────────────────────────────
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW=1 minute

# ──────────────────────────────────────────────
# Scheduler
# ──────────────────────────────────────────────
# Admission controller interval (ms)
ADMISSION_INTERVAL_MS=1000
# Garbage collector interval (ms)
GC_INTERVAL_MS=5000
# Number of wait queue entries to scan per GC cycle
GC_SCAN_COUNT=100

# ──────────────────────────────────────────────
# Ticket
# ──────────────────────────────────────────────
# TTL for ticket heartbeat key (seconds)
TICKET_TTL_SECONDS=60
